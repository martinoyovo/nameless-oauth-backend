# OAuth backend environment variables.
#
# Local dev:
#   1. cp .env.example .env
#   2. Fill in the values from your Notion integration
#   3. npm start
#   4. (separately) ngrok http 3000 → update NOTION_REDIRECT_URI to the ngrok URL
#
# Production (Vercel):
#   Set these via the Vercel dashboard → Project Settings → Environment Variables.
#   Don't commit .env.

# From https://www.notion.so/my-integrations → your integration → "OAuth Domain & URIs"
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# The full callback URL.
#   Local dev:  https://<random>.ngrok.io/oauth/notion/callback
#   Production: https://<your-project>.vercel.app/oauth/notion/callback
# Must match exactly what's listed under "Redirect URIs" in the Notion integration settings.
NOTION_REDIRECT_URI=

# Optional. Only used by `npm start` (Vercel ignores PORT).
PORT=3000
